# Copy this file to .env.local and fill in real values. Never commit
# .env.local itself — only this .example file (documented placeholders
# only, no real secrets) is tracked in git.

# --- Telegram booking notifications ---------------------------------------
# The /book page's native booking flow sends a Telegram message to the
# founder whenever a visitor confirms a booking (src/app/api/book/route.ts).
#
# 1. Create a bot:
#    - In Telegram, message @BotFather and send /newbot.
#    - Follow the prompts to name your bot; BotFather will reply with a
#      bot token that looks like 123456789:ABCdefGhIJKlmNoPQRstuVwxYZ.
#    - Set that value as TELEGRAM_BOT_TOKEN below.
TELEGRAM_BOT_TOKEN=123456789:REPLACE_WITH_YOUR_BOTFATHER_TOKEN

# 2. Get your chat ID:
#    - Send any message to your new bot (search for its @username and
#      press Start), OR forward a message from yourself to a helper bot
#      such as @userinfobot or @getidsbot and read the numeric ID it
#      replies with.
#    - Alternatively, after messaging your bot, visit
#      https://api.telegram.org/bot<TOKEN>/getUpdates in a browser
#      (substituting your real token) and read the numeric "chat":{"id":...}
#      value from the JSON response.
#    - Set that numeric value as TELEGRAM_CHAT_ID below.
TELEGRAM_CHAT_ID=REPLACE_WITH_YOUR_NUMERIC_CHAT_ID

# --- Cloudflare Web Analytics -----------------------------------------------
# Site-wide traffic analytics (page views, referrers, devices, and
# country/region-level location) rendered in src/app/layout.tsx. Free,
# privacy-first — no cookies, no fingerprinting, no raw visitor IP ever
# collected or shown, so no cookie-consent banner is required for this.
#
# 1. Sign up free at https://dash.cloudflare.com (no domain/DNS migration
#    needed — Web Analytics works on any site via a JS snippet).
# 2. Go to Analytics & Logs -> Web Analytics -> Add a site.
# 3. Choose "I'm not using Cloudflare for my site" / JavaScript snippet
#    setup, enter aideployed.dev, and copy the token from the generated
#    <script data-cf-beacon='{"token": "..."}'> snippet — just the token
#    value, not the whole snippet.
# 4. Set that value as NEXT_PUBLIC_CF_BEACON_TOKEN below. NEXT_PUBLIC_ is
#    required (and safe) here — this token is a public identifier embedded
#    directly in the page's HTML, not a secret.
NEXT_PUBLIC_CF_BEACON_TOKEN=REPLACE_WITH_YOUR_CLOUDFLARE_BEACON_TOKEN

# --- Netlify Blobs (booking + availability storage) -------------------------
# No env vars needed here — Netlify injects Blobs access automatically for
# deployed sites. Locally, Blobs is ONLY reachable when running through the
# Netlify CLI's dev server (it provides a sandboxed local store), not plain
# `next dev`:
#
#   npx netlify dev
#
# `npx netlify link` (one-time, requires a free Netlify account + this site
# already existing on Netlify) may be needed first so the CLI knows which
# site's dev environment to emulate.

# --- Resend (booking confirmation/cancellation/reschedule emails) ----------
# 1. Sign up free at https://resend.com.
# 2. Domains -> Add Domain -> aideployed.dev -> add the SPF/DKIM DNS records
#    Resend shows you at whatever host manages aideployed.dev's DNS.
#    Verification can take a few minutes to a few hours depending on DNS
#    propagation. Until verified, you can send test emails from Resend's
#    shared sandbox sender, but production visitor-facing sends require the
#    verified domain.
# 3. API Keys -> Create API Key (sending access) -> copy the value
#    immediately, it's only shown once.
RESEND_API_KEY=re_REPLACE_WITH_YOUR_RESEND_API_KEY

# --- Admin auth (availability management at /admin) -------------------------
# ADMIN_PASSWORD: the password you type in at /admin/login. Pick a long,
# random value.
# ADMIN_SESSION_SECRET: a separate random secret used to HMAC-sign the
# session cookie so the cookie itself never holds the plaintext password.
# Generate a strong value for each, e.g.:
#
#   openssl rand -hex 32
#
ADMIN_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_PASSWORD
ADMIN_SESSION_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# --- Upstash Redis (per-IP rate limiting on /api/book + /api/admin/login) ---
# Caps booking attempts (5/IP/hour) and admin login attempts (10/IP/hour) so
# a bot or attacker can't run up Netlify Function/Blobs usage or Resend email
# volume by hammering these two public endpoints. If unset, rate limiting is
# skipped (logged, not a hard failure) — booking/login still work, just
# unprotected, so set these before real traffic.
#
# 1. Sign up free at https://upstash.com -> create a Redis database (any
#    free-tier region close to your Netlify site is fine).
# 2. On the database's page, copy the "UPSTASH_REDIS_REST_URL" and
#    "UPSTASH_REDIS_REST_TOKEN" values shown under the REST API section.
UPSTASH_REDIS_REST_URL=REPLACE_WITH_YOUR_UPSTASH_REDIS_REST_URL
UPSTASH_REDIS_REST_TOKEN=REPLACE_WITH_YOUR_UPSTASH_REDIS_REST_TOKEN
