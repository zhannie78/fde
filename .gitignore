# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# git worktrees (local scratch, never tracked)
.worktrees/

# subagent-driven-development scratch (briefs, reports, review packages)
.superpowers/

# typescript
*.tsbuildinfo
next-env.d.ts

# Local Netlify folder
.netlify

# Netlify CLI Edge Functions bootstrap lockfile (Deno, auto-generated)
deno.lock
